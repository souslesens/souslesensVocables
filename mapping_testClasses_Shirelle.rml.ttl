@prefix tm: <http://ex.com/triplesMap/> .
@prefix pom: <http://ex.com/preObjMap/> .
@prefix ls: <http://ex.com/logicalSource/> .
@prefix pm: <http://ex.com/predicateMap/> .
@prefix om: <http://ex.com/objectMap/> .
@prefix sm: <http://ex.com/subjectMap/> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rml: <http://semweb.mmlab.be/ns/rml#> .
@prefix ql: <http://semweb.mmlab.be/ns/ql#> .
@prefix rr: <http://www.w3.org/ns/r2rml#> .

<http://example.com#JC1> a rr:Join;
    rr:child "author_id";
    rr:parent "author_id".
<http://example.com#LogicalSource1> rml:referenceFormulation ql:CSV;
    rml:source "CSV__authors_csv.csv";
    a rml:LogicalSource.
<http://example.com#LogicalSource2> rml:referenceFormulation ql:CSV;
    rml:source "CSV__books_csv.csv";
    a rml:LogicalSource.
<http://example.com#OM1> <http://purl.org/dc/terms/identifier> "0"^^<http://www.w3.org/2001/XMLSchema#integer>;
    a rr:ObjectMap;
    rml:reference "author_name";
    rr:datatype <http://www.w3.org/2001/XMLSchema#string>.
<http://example.com#OM2> <http://purl.org/dc/terms/identifier> "1"^^<http://www.w3.org/2001/XMLSchema#integer>;
    a rr:ObjectMap;
    rr:constant <http://testClasses_Shirelle/Author>;
    rr:termType rr:IRI.
<http://example.com#OM3> <http://purl.org/dc/terms/identifier> "2"^^<http://www.w3.org/2001/XMLSchema#integer>;
    a rr:ObjectMap;
    rml:reference "title";
    rr:datatype <http://www.w3.org/2001/XMLSchema#string>.
<http://example.com#OM4> <http://purl.org/dc/terms/identifier> "3"^^<http://www.w3.org/2001/XMLSchema#integer>;
    a rr:ObjectMap;
    rr:constant <http://testClasses_Shirelle/Book>;
    rr:termType rr:IRI.
<http://example.com#OM5> <http://purl.org/dc/terms/identifier> "4"^^<http://www.w3.org/2001/XMLSchema#integer>;
    a rr:RefObjectMap;
    rr:parentTriplesMap <http://example.com#TriplesMap1>;
    rr:joinCondition <http://example.com#JC1>.
<http://example.com#PM1> a rr:PredicateMap;
    rr:constant <http://www.w3.org/2000/01/rdf-schema#label>.
<http://example.com#PM2> a rr:PredicateMap;
    rr:constant rdf:type.
<http://example.com#PM3> a rr:PredicateMap;
    rr:constant <http://www.w3.org/2000/01/rdf-schema#label>.
<http://example.com#PM4> a rr:PredicateMap;
    rr:constant rdf:type.
<http://example.com#PM5> a rr:PredicateMap;
    rr:constant <https://spec.industrialontologies.org/ontology/construct/prescribes>.
<http://example.com#POM1> <http://purl.org/dc/terms/identifier> "0"^^<http://www.w3.org/2001/XMLSchema#integer>;
    a rr:PredicateObjectMap;
    rr:objectMap <http://example.com#OM1>;
    rr:predicateMap <http://example.com#PM1>.
<http://example.com#POM2> <http://purl.org/dc/terms/identifier> "1"^^<http://www.w3.org/2001/XMLSchema#integer>;
    a rr:PredicateObjectMap;
    rr:objectMap <http://example.com#OM2>;
    rr:predicateMap <http://example.com#PM2>.
<http://example.com#POM3> <http://purl.org/dc/terms/identifier> "2"^^<http://www.w3.org/2001/XMLSchema#integer>;
    a rr:PredicateObjectMap;
    rr:objectMap <http://example.com#OM3>;
    rr:predicateMap <http://example.com#PM3>.
<http://example.com#POM4> <http://purl.org/dc/terms/identifier> "3"^^<http://www.w3.org/2001/XMLSchema#integer>;
    a rr:PredicateObjectMap;
    rr:objectMap <http://example.com#OM4>;
    rr:predicateMap <http://example.com#PM4>.
<http://example.com#POM5> <http://purl.org/dc/terms/identifier> "4"^^<http://www.w3.org/2001/XMLSchema#integer>;
    a rr:PredicateObjectMap;
    rr:objectMap <http://example.com#OM5>;
    rr:predicateMap <http://example.com#PM5>.
<http://example.com#SM1> <http://purl.org/dc/terms/identifier> "0"^^<http://www.w3.org/2001/XMLSchema#integer>;
    a rr:SubjectMap;
    rr:template "http://testClasses_Shirelle/{author_id}";
    rr:termType rr:IRI.
<http://example.com#SM2> <http://purl.org/dc/terms/identifier> "1"^^<http://www.w3.org/2001/XMLSchema#integer>;
    a rr:SubjectMap;
    rr:template "http://testClasses_Shirelle/{book_id}";
    rr:termType rr:IRI.
<http://example.com#TriplesMap1> <http://purl.org/dc/terms/identifier> "0"^^<http://www.w3.org/2001/XMLSchema#integer>;
    rml:logicalSource <http://example.com#LogicalSource1>;
    a rr:TriplesMap;
    rr:predicateObjectMap <http://example.com#POM1>, <http://example.com#POM2>;
    rr:subjectMap <http://example.com#SM1>.
<http://example.com#TriplesMap2> <http://purl.org/dc/terms/identifier> "1"^^<http://www.w3.org/2001/XMLSchema#integer>;
    rml:logicalSource <http://example.com#LogicalSource2>;
    a rr:TriplesMap;
    rr:predicateObjectMap <http://example.com#POM3>, <http://example.com#POM4>, <http://example.com#POM5>;
    rr:subjectMap <http://example.com#SM2>.
