@base <http://example.org/mapping/> .
@prefix rr:   <http://www.w3.org/ns/r2rml#> .
@prefix rml:  <http://semweb.mmlab.be/ns/rml#> .
@prefix ql:   <http://semweb.mmlab.be/ns/ql#> .
@prefix ex:   <http://example.org/> .
@prefix schema: <http://schema.org/> .
@prefix xsd:  <http://www.w3.org/2001/XMLSchema#> .

<#MoviesMapping>
  a rr:TriplesMap ;
  rml:logicalSource [
    rml:source "movie.csv" ;
    rml:referenceFormulation ql:CSV
  ] ;
  rr:subjectMap [
    rr:template "http://example.org/movie/{ID}" ;
    rr:class schema:Movie
  ] ;
  rr:predicateObjectMap [
    rr:predicate schema:name ;
    rr:objectMap [ rml:reference "title" ]
  ] ;
  rr:predicateObjectMap [
    rr:predicate schema:datePublished ;
    rr:objectMap [ rml:reference "release" ; rr:datatype xsd:gYear ]
  ] ;
  rr:predicateObjectMap [
    rr:predicate ex:directorId ;
    rr:objectMap [ rml:reference "director_id" ]
  ] .
