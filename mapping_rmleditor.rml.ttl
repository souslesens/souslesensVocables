@prefix tm: <http://ex.com/triplesMap/>.
@prefix pom: <http://ex.com/preObjMap/>.
@prefix ls: <http://ex.com/logicalSource/>.
@prefix pm: <http://ex.com/predicateMap/>.
@prefix om: <http://ex.com/objectMap/>.
@prefix sm: <http://ex.com/subjectMap/>.
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#>.
@prefix rml: <http://semweb.mmlab.be/ns/rml#>.
@prefix ql: <http://semweb.mmlab.be/ns/ql#>.
@prefix rr: <http://www.w3.org/ns/r2rml#>.

<http://example.com#JC15> a rr:JoinCondition;
    rr:child "author_id";
    rr:parent "author_id".
<http://example.com#LogicalSource2> rml:referenceFormulation ql:CSV;
    rml:source "CSV__books_csv.csv";
    a rml:LogicalSource.
<http://example.com#LogicalSource8> rml:referenceFormulation ql:CSV;
    rml:source "CSV__authors_csv.csv";
    a rml:LogicalSource.
<http://example.com#OM10> a rr:ObjectMap;
    rr:constant <http://testClasses_Shirelle/Author>;
    rr:termType rr:IRI.
<http://example.com#OM13> a rr:ObjectMap;
    rr:joinCondition <http://example.com#JC15>;
    rr:parentTriplesMap <http://example.com#TriplesMap6>.
<http://example.com#OM17> <http://purl.org/dc/terms/identifier> "4"^^<http://www.w3.org/2001/XMLSchema#integer>;
    rml:reference "title";
    a rr:ObjectMap.
<http://example.com#OM20> <http://purl.org/dc/terms/identifier> "7"^^<http://www.w3.org/2001/XMLSchema#integer>;
    rml:reference "author_name";
    a rr:ObjectMap.
<http://example.com#OM4> a rr:ObjectMap;
    rr:constant <http://testClasses_Shirelle/Book>;
    rr:termType rr:IRI.
<http://example.com#PM11> a rr:PredicateMap;
    rr:constant rdf:type.
<http://example.com#PM14> a rr:PredicateMap;
    rr:template "https://spec.industrialontologies.org/ontology/construct/prescribes".
<http://example.com#PM18> a rr:PredicateMap;
    rr:template "http://www.w3.org/2000/01/rdf-schema#label".
<http://example.com#PM21> a rr:PredicateMap;
    rr:template "http://www.w3.org/2000/01/rdf-schema#label".
<http://example.com#PM5> a rr:PredicateMap;
    rr:constant rdf:type.
<http://example.com#POM12> <http://purl.org/dc/terms/identifier> "2"^^<http://www.w3.org/2001/XMLSchema#integer>;
    a rr:PredicateObjectMap;
    rr:objectMap <http://example.com#OM13>;
    rr:predicateMap <http://example.com#PM14>.
<http://example.com#POM16> <http://purl.org/dc/terms/identifier> "5"^^<http://www.w3.org/2001/XMLSchema#integer>;
    a rr:PredicateObjectMap;
    rr:objectMap <http://example.com#OM17>;
    rr:predicateMap <http://example.com#PM18>.
<http://example.com#POM19> <http://purl.org/dc/terms/identifier> "8"^^<http://www.w3.org/2001/XMLSchema#integer>;
    a rr:PredicateObjectMap;
    rr:objectMap <http://example.com#OM20>;
    rr:predicateMap <http://example.com#PM21>.
<http://example.com#POM3> <http://purl.org/dc/terms/identifier> "0"^^<http://www.w3.org/2001/XMLSchema#integer>;
    a rr:PredicateObjectMap;
    rr:objectMap <http://example.com#OM4>;
    rr:predicateMap <http://example.com#PM5>.
<http://example.com#POM9> <http://purl.org/dc/terms/identifier> "1"^^<http://www.w3.org/2001/XMLSchema#integer>;
    a rr:PredicateObjectMap;
    rr:objectMap <http://example.com#OM10>;
    rr:predicateMap <http://example.com#PM11>.
<http://example.com#SM1> <http://purl.org/dc/terms/identifier> "0"^^<http://www.w3.org/2001/XMLSchema#integer>;
    a rml:SubjectMap;
    rr:template "http://testClasses_Shirelle/{book_id}".
<http://example.com#SM7> <http://purl.org/dc/terms/identifier> "1"^^<http://www.w3.org/2001/XMLSchema#integer>;
    a rml:SubjectMap;
    rr:template "http://testClasses_Shirelle/{author_id}".
<http://example.com#TriplesMap0> <http://purl.org/dc/terms/identifier> "0"^^<http://www.w3.org/2001/XMLSchema#integer>;
    rml:logicalSource <http://example.com#LogicalSource2>;
    a rr:TriplesMap;
    rr:predicateObjectMap <http://example.com#POM12>, <http://example.com#POM16>, <http://example.com#POM3>;
    rr:subjectMap <http://example.com#SM1>.
<http://example.com#TriplesMap6> <http://purl.org/dc/terms/identifier> "1"^^<http://www.w3.org/2001/XMLSchema#integer>;
    rml:logicalSource <http://example.com#LogicalSource8>;
    a rr:TriplesMap;
    rr:predicateObjectMap <http://example.com#POM19>, <http://example.com#POM9>;
    rr:subjectMap <http://example.com#SM7>.
